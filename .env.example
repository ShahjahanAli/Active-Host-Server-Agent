NODE_ENV=production

# URL of your RSM Next.js app — no trailing slash
APP_URL=https://rsm.yourdomain.com

# Host ID from the RSM dashboard (Hosts page)
AGENT_ID=agt_replace_with_your_agent_id

# Raw API key — shown once when generated in the dashboard
AGENT_API_KEY=rsm_replace_with_your_api_key

# Local HTTP port for /health and /status endpoints
AGENT_PORT=4800

# Agent build version (set automatically when using the published package)
AGENT_VERSION=0.1.0

# How often (ms) the agent polls for queued commands
POLL_INTERVAL_MS=5000

# How often (ms) system metrics are pushed
METRICS_INTERVAL_MS=30000

# Max command execution time (ms) — default 5 min
COMMAND_TIMEOUT_MS=300000
