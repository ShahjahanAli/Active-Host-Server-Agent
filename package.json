{
  "name": "rsm-agent",
  "version": "0.1.0",
  "description": "Remote Server Manager — lightweight host agent. Poll-based command execution & metrics push.",
  "homepage": "https://github.com/your-org/rsm-agent#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/rsm-agent.git"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "main": "dist/index.js",
  "bin": {
    "rsm-agent": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    ".env.example"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "postbuild": "node -e \"require('fs').chmodSync('dist/index.js', '755')\"",
    "start": "node dist/index.js",
    "prepare": "npm run build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "dotenv": "17.3.1",
    "express": "5.2.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/express": "5.0.6",
    "@types/node": "25.3.1",
    "eslint": "10.0.2",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  }
}
